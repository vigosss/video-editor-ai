{
  "name": "video-editor-ai",
  "version": "0.1.0",
  "description": "老兵AI智剪 - AI驱动的智能视频剪辑桌面应用",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "postinstall": "electron-rebuild -f -o better-sqlite3",
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:dev": "vite build",
    "preview": "vite preview",
    "prepare:ffmpeg": "node scripts/prepare-ffmpeg.js",
    "package": "yarn run build && yarn run prepare:ffmpeg && electron-builder --dir --win",
    "dist": "yarn run build && yarn run prepare:ffmpeg && electron-builder --win",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\""
  },
  "dependencies": {
    "@electron-toolkit/utils": "^3.0.0",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@napi-rs/whisper": "^0.0.4",
    "@uiw/react-textarea-code-editor": "^3.1.1",
    "better-sqlite3": "^11.6.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.0",
    "electron-updater": "^6.3.9",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "follow-redirects": "^1.15.11",
    "lucide-react": "^0.460.0",
    "motion": "^11.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "react-toastify": "^10.0.6",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/better-sqlite3": "^7.6.8",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/follow-redirects": "^1.14.4",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
